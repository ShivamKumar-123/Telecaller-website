# Optional. In dev, if unset, the app uses same-origin "/api" (Vite proxies to Django).
# `npm run preview` also proxies /api (see vite.config.js); if you skip that, set:
# VITE_API_URL=http://127.0.0.1:8000/api
#
# Must include the /api path (Django mounts routes under /api/).
# VITE_API_URL=http://127.0.0.1:8000/api

# Wrong (returns HTML / login page from wrong server):
# VITE_API_URL=http://localhost:5173

# After pulling new API routes, restart: python manage.py runserver

# Public site origin for SEO (canonical, Open Graph, Twitter). No trailing slash.
# Production example: VITE_SITE_URL=https://yourdomain.com
# If unset, build falls back to http://localhost:5173
# VITE_SITE_URL=
